# Slack app credentials (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# Socket Mode app-level token (xapp-...). Lets us run without a public URL — ideal for demos.
SLACK_APP_TOKEN=xapp-...
# OPTIONAL user token (xoxp-) with search:read — enables Slack message search.
# search.messages does NOT work with a bot token; leave blank to skip that leg.
SLACK_USER_TOKEN=

# Anthropic — powers the failure forecast synthesis
ANTHROPIC_API_KEY=sk-ant-...
OMEN_MODEL=claude-opus-4-8

# GitHub (MCP grounding source) — a PAT with repo read scope for the demo org
GITHUB_TOKEN=ghp_...
# The repo to mine for incidents/PRs, format: owner/repo  e.g. acme-org/payments
GITHUB_REPO=your-org/your-repo
# MCP mode for GitHub grounding:
#   local  (default) — our own MCP server over stdio; no network endpoint, best for demos
#   remote           — GitHub's OFFICIAL remote MCP server (api.githubcopilot.com/mcp) via your PAT
GITHUB_MCP_MODE=local

# Tavily real-time search API (https://tavily.com) — external comparable failures
TAVILY_API_KEY=tvly-...

# API key for dashboard access — set this to a non-empty value to protect POST endpoints.
# Without it, anyone can trigger forecasts and burn API credits.
# Leave empty for local dev only.
OMEN_API_KEY=

# Restrict CORS to a specific origin (e.g. your Vercel frontend URL).
# Defaults to "*" (all origins) if unset.
OMEN_ALLOWED_ORIGIN=

# Bolt Socket Mode port
PORT=3000
# REST + SSE API port (consumed by the React dashboard)
API_PORT=3001
