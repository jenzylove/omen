# URL of the Omen API server (default: http://localhost:3001)
# For a Vercel deploy, set this to your hosted backend, e.g. https://omen-api.up.railway.app
VITE_API_URL=http://localhost:3001

# Optional — only if the backend sets OMEN_API_KEY to gate the forecast endpoint.
# Must match the server's OMEN_API_KEY. Bundled into the client, so treat it as
# abuse-deterrence (with the server's rate limit + CORS lock), not a true secret.
VITE_OMEN_API_KEY=
